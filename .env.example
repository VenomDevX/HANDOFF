NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
GEMINI_API_KEY=
AI_PROVIDER=gemini
NEXT_PUBLIC_APP_URL=
TEST_USER_PASSWORD=
NEXT_PUBLIC_TEST_USER_PASSWORD=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Server-only, 32-byte base64 key for lib/security/encryption.ts (AES-256-GCM).
# Required for encrypting/decrypting integration secrets (e.g. the GitHub
# repo-integration OAuth access token below). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# GitHub OAuth App for the org-level repo integration
# (app/api/v1/integrations/github/**) — connects a workspace's GitHub account
# so repos/PRs/commits can be imported and synced. Distinct from
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID/_SECRET below, which are for
# Supabase Auth "Continue with GitHub" login/signup.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth App used ONLY for Supabase Auth "Continue with GitHub" login/signup.
# Distinct from GITHUB_CLIENT_ID/GITHUB_CLIENT_SECRET above, which belong to the
# separate org-level repo integration (app/api/v1/integrations/github/**).
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
