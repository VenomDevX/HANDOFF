# =============================================================================
# Handoff — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser; keep
# every secret WITHOUT that prefix so it stays server-side only.
# =============================================================================

# --- Supabase (client-safe) --------------------------------------------------
# The URL and publishable/anon key are safe to expose to the browser ONLY
# because Row Level Security is enabled on every table. If you add a table,
# enable RLS on it before shipping or the anon key exposes your data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only, NEVER expose to the browser) ---------------------
# Service-role / secret key BYPASSES RLS. Must never appear in client code or
# carry a NEXT_PUBLIC_ prefix. Used only by lib/supabase/admin.ts and scripts.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# --- AI (server-only) --------------------------------------------------------
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Encryption (server-only) ------------------------------------------------
# 32-byte base64 key for lib/security/encryption.ts (AES-256-GCM), used to
# encrypt integration secrets (e.g. the GitHub repo OAuth access token).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# HMAC secret for hashing audit-log IP / user-agent (server-only). Falls back to
# SUPABASE_SECRET_KEY if unset. REQUIRED in production — the app fails closed
# rather than using any hardcoded default.
AUDIT_HMAC_SECRET=

# --- GitHub OAuth: org-level repo integration (server-only) ------------------
# app/api/v1/integrations/github/** — connects a workspace's GitHub account so
# repos/PRs/commits can be imported and synced. Distinct from the Supabase Auth
# "Continue with GitHub" credentials below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Supabase Auth external providers (server-only) --------------------------
# Used ONLY for "Continue with GitHub/Google" login/signup. Distinct from the
# org-level repo integration credentials above.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# --- Upstash Redis cache / rate limiting (server-only) -----------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email / SMTP (server-only) ----------------------------------------------
# Point at a real provider (Resend/Postmark/etc.) in production.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REPORTS_FROM_EMAIL=

# --- Cron / scheduled job auth (server-only) ---------------------------------
# Shared secret that authenticates the Vercel cron call to /api/v1/demo/cleanup
# and the standalone cleanup script.
CRON_SECRET=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# --- Test / demo only --------------------------------------------------------
# Shared password for local seed/demo accounts. NEXT_PUBLIC_ variant is exposed
# to the browser on purpose so the demo login can prefill it — use ONLY with
# throwaway seed accounts, never a real credential.
TEST_USER_PASSWORD=
NEXT_PUBLIC_TEST_USER_PASSWORD=
